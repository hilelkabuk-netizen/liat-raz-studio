generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model ClassType {
  id          String   @id @default(cuid())
  name        String
  description String
  price       String
  schedule    String
  imageUrl    String?
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Product {
  id          String      @id @default(cuid())
  name        String
  description String?
  category    String
  price       Int
  dimensions  String?
  imageUrl    String
  inStock     Boolean     @default(true)
  order       Int         @default(0)
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orderItems  OrderItem[]
}

model VoucherType {
  id          String   @id @default(cuid())
  name        String
  description String
  price       Int
  active      Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orders      Order[]
}

model GalleryImage {
  id        String   @id @default(cuid())
  imageUrl  String
  alt       String
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Order {
  id              String       @id @default(cuid())
  type            String
  status          String       @default("pending")
  totalAmount     Int
  customerName    String
  customerEmail   String
  customerPhone   String?
  recipientName   String?
  recipientEmail  String?
  paymentId       String?
  voucherTypeId   String?
  voucherType     VoucherType? @relation(fields: [voucherTypeId], references: [id])
  items           OrderItem[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int     @default(1)
  price     Int
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  phone     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model SiteContent {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model Admin {
  id       String @id @default(cuid())
  email    String @unique
  password String
}
